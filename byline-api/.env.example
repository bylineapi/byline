# ─────────────────────────────────────────
# BYLINE API — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env a Git
# ─────────────────────────────────────────

# Base de datos Neon.tech
# Obtener en: console.neon.tech → tu proyecto → Connection Details
# Formato: postgresql+asyncpg://user:password@ep-xxx.us-west-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-west-2.aws.neon.tech/dbname?sslmode=require

# Clave para el panel de administración del dueño
# Mínimo 32 caracteres, generarla con: openssl rand -hex 32
ADMIN_SECRET=cambia-esto-por-una-clave-segura-minimo-32-caracteres

# Clave interna para tokens
# Mínimo 32 caracteres, generarla con: openssl rand -hex 32
SECRET_KEY=cambia-esto-por-otra-clave-segura-minimo-32-caracteres

# URL externa de Render (para keep-alive)
# Render la agrega automáticamente, pero puedes definirla manualmente
# RENDER_EXTERNAL_URL=https://byline-dgpt.onrender.com/